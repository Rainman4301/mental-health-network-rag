# ---------------------------------------------------------------------------
# .env.example — copy this to .env and fill in your actual values.
# .env is listed in .gitignore and should NEVER be committed.
# ---------------------------------------------------------------------------

# ── Host/container UID mapping (fixes bind-mount permission errors) ─────────
# Run `id -u` on your VM and paste the result here, e.g. AIRFLOW_UID=1000
AIRFLOW_UID=50000

# ── Airflow secrets ───────────────────────────────────────────────────────
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=

# Generate with:
#   python -c "import secrets; print(secrets.token_hex(16))"
AIRFLOW_WEBSERVER_SECRET_KEY=

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# Azure Blob container name (will be created if it doesn't exist)
AZURE_CONTAINER_NAME=mh-etl-data

# Beyond Blue scraping targets — comma-separated category slugs
BEYONDBLUE_TAGS=anxiety,depression,ptsd-and-trauma,suicidal-thoughts-and-self-harm

# How many forum list pages to scrape per run (keep low during testing)
SCRAPE_PAGES=2

# Parallel worker threads for comment scraping (each holds one persistent
# headless Chrome instance). On an 8GB+ VM, 3-5 is reasonable.
MAX_WORKERS=3

# SentenceTransformer model used in script 2
EMBED_MODEL=all-MiniLM-L6-v2

# Posts shorter than this many words (after cleaning) are dropped before
# embedding/topic modeling — short docs add little signal to BERTopic.
MIN_WORDS=3